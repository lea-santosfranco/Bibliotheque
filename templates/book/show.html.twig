{% extends 'base.html.twig' %}

{% block title %}Détails du livre
{% endblock %}

{% block body %}
	<div class="container">
		<h1>Fiche détaillée du livre</h1>

		<hr>

		<div class="row">
			<div class="col-md-4">
				<div style="width: 200px; height: 300px; background-color: #eee; display: flex; align-items: center; justify-content: center; border: 1px solid #ccc;">
					<span>Couverture</span>
				</div>
			</div>

			<div class="col-md-8">
				<h2>Titre :
					{{ livre.titre | default('Titre inconnu') }}</h2>
				<p>
					<strong>Auteur :</strong>
					{{ livre.auteur | default('Auteur anonyme') }}</p>
				<p>
					<strong>Résumé :</strong>
				</p>
				<p>{{ livre.resume | default('Aucun résumé disponible pour ce livre.') }}</p>

				<p>
					<strong>Statut :</strong>
					{% if book.stock > 0 %}
						<span class="badge bg-success">Disponible</span>
					{% else %}
						<span class="badge bg-danger">Indisponible</span>
					{% endif %}
				</p>

				<a href="{{ path('app_home') }}" class="btn btn-secondary">Retour à la liste</a>
				<button class="btn btn-primary">Emprunter ce livre</button>
			</div>
		</div>
	</div>
{% endblock %}
